        });

        // Update notification settings
        const updatedSettings = {
          ...notificationSettings,
          enabled: true,
          subscribed: true,
          subscription: subscription
        };
        
        setNotificationSettings(updatedSettings);
        
        // Save to storage
        const fullSettings = loadFromStorage('northstar_settings', {});
        fullSettings.notifications = updatedSettings;
        saveToStorage('northstar_settings', fullSettings);
        saveToStorage('northstar_push', subscription);

        sendPipMessage("🔔 Daily reminders enabled! I'll send you a gentle penguin nudge every day. 🐧💙");

      } else {
        // Unsubscribe
        const registration = await navigator.serviceWorker.getRegistration();
        const subscription = await registration?.pushManager.getSubscription();
        
        if (subscription) {
          await subscription.unsubscribe();
        }

        // Update notification settings
        const updatedSettings = {
          ...notificationSettings,
          enabled: false,
          subscribed: false,
          subscription: null
        };
        
        setNotificationSettings(updatedSettings);
        
        // Save to storage
        const fullSettings = loadFromStorage('northstar_settings', {});
        fullSettings.notifications = updatedSettings;
        saveToStorage('northstar_settings', fullSettings);
        localStorage.removeItem('northstar_push');

        sendPipMessage("🔕 Daily reminders disabled. I'll miss sending you those little penguin notes! 🐧💙");
      }
    } catch (error) {
      console.error('Failed to toggle notifications:', error);

      {/* Sidebar */}
      <div className={`
        fixed inset-y-0 left-0 z-50 w-80 bg-white shadow-lg transform transition-transform duration-300 ease-in-out
        ${sidebarOpen ? 'translate-x-0' : '-translate-x-full'}
        lg:relative lg:translate-x-0
      `}>
        <div className="h-full flex flex-col p-6">

          {/* User profile */}
          <div className="mb-6">
            <div className="flex items-center gap-3 mb-4">
              <div>
                <h2 className="font-semibold text-gray-800">Hi, {user.name}!</h2>
                <p className="text-sm text-gray-600">Chatting with Pip</p>
              </div>
            </div>
          </div>

          {/* Streak counter */}
          <div className="mb-6">
            <StreakCounter
              streak={streak}
              size="sm"
              showDetails={true}
            />
          </div>

          {/* Quick actions */}
          <div className="space-y-3 mb-6">
            <button
              onClick={() => setShowMoodPicker(true)}
              className="w-full btn-secondary text-left p-3 rounded-lg"
            >
              📊 Check your mood
            </button>

            <button
              onClick={() => router.push('/journal')}
              className="w-full btn-secondary text-left p-3 rounded-lg"
            >

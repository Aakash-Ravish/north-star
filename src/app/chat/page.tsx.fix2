          {dailyQuote && (
            <div className="mb-6 animate-fade-in">
              <div className="bg-gradient-to-r from-yellow-50 to-amber-50 border border-yellow-200 rounded-2xl p-4 shadow-sm">
                <div className="flex items-start gap-3">
                  <div className="flex-shrink-0 mt-1">
                    <PipPenguin size="sm" mood="playful" />
                  </div>
                  <div className="flex-1">
                    <div className="flex items-center justify-between mb-2">
                      <div className="flex items-center gap-2">
                        <h3 className="text-sm font-semibold text-amber-800">
                          ✨ Daily Inspiration
                        </h3>
                        <span className="text-xs text-amber-600 bg-amber-100 px-2 py-1 rounded-full">
                          {new Date().toLocaleDateString('en-US', {
                            month: 'short',
                            day: 'numeric'
                          })}
                        </span>
                      </div>
                      <button
                        onClick={refreshDailyQuote}
                        className="p-1 text-amber-600 hover:text-amber-800 hover:bg-amber-100 rounded-full transition-colors"
                        title="Get a new quote"
                      >
                        <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                        </svg>
                      </button>
                    </div>
                    <p className="text-amber-900 leading-relaxed text-sm font-medium">
                      {dailyQuote.quote}
                    </p>
                    {dailyQuote.fallback && (
                      <p className="text-xs text-amber-600 mt-2 opacity-75">
                        💙 Cached message from Pip
                      </p>
                    )}
                  </div>
                </div>
              </div>
            </div>
          )}

          {messages.map((message) => (
            <ChatBubble
              key={message.id}
              message={message}
              showAvatar={true}
              onShare={handleShareMessage}
            />
          ))}

          {/* Typing indicator - only show when thinking */}
          {isTyping && pipAnimation.state === 'thinking' && (
            <ChatBubble
              message={{
                id: 'typing',
                content: '',
                sender: 'pip',
                timestamp: new Date(),
                type: 'text'
              }}
              isTyping={true}
              showAvatar={true}
            />
          )}

          <div ref={messagesEndRef} />
        </div>

        {/* Mood picker overlay */}
        {showMoodPicker && (
          <div className="absolute inset-0 bg-black bg-opacity-50 flex items-center justify-center z-30 p-4">
            <div className="bg-white rounded-2xl p-6 max-w-md w-full animate-slide-in-up">
              <div className="text-center mb-6">
                <PipPenguin size="md" mood="happy" className="mb-4 mx-auto" />
                <h3 className="text-xl font-semibold text-gray-800 mb-2">
                  Daily Mood Check-in
                </h3>
                <p className="text-gray-600">
                  How are you feeling today?
                </p>
              </div>

              <MoodPicker
                onMoodSelect={handleMoodSelect}
                showLabels={true}
              />

              <button
                onClick={() => setShowMoodPicker(false)}
                className="w-full mt-4 text-gray-500 hover:text-gray-700 text-sm"
              >
                Skip for now
              </button>
            </div>
          </div>
        )}

        {/* Streak celebration overlay */}
        {showStreakCelebration && (
          <div className="absolute inset-0 bg-black bg-opacity-50 flex items-center justify-center z-40 p-4">
            <div className="bg-white rounded-2xl p-8 max-w-sm w-full animate-slide-in-up text-center">
              <div className="mb-6">
                <PipPenguin
                  size="lg"
                  mood="playful"
                  className="mb-4 mx-auto animate-pulse-gentle"
                />

                {/* Celebration effects */}
                <div className="relative">
                  <div className="text-6xl mb-4 animate-bounce">
                    {getStreakEmoji(celebrationStreak)}
                  </div>

                  {/* Floating emojis */}
                  <div className="absolute -top-8 -left-4 text-2xl animate-bounce" style={{ animationDelay: '0.2s' }}>🎉</div>
                  <div className="absolute -top-6 -right-2 text-2xl animate-bounce" style={{ animationDelay: '0.4s' }}>✨</div>
                  <div className="absolute -top-10 left-1/2 text-2xl animate-bounce" style={{ animationDelay: '0.6s' }}>🌟</div>
                </div>

                <h3 className="text-2xl font-bold text-gray-800 mb-2">
                  {celebrationStreak} Day Streak! 🔥
                </h3>

                <p className="text-gray-600 mb-4">
                  {getStreakMessage(celebrationStreak)}
                </p>

                <div className="bg-gradient-to-r from-orange-50 to-yellow-50 border border-orange-200 rounded-xl p-4 mb-6">
                  <div className="flex items-center justify-center gap-2 text-orange-700">
                    <span className="text-2xl">🔥</span>
                    <span className="text-xl font-bold">{celebrationStreak}</span>
                    <span className="text-sm">consecutive days</span>
                  </div>
                </div>

                <button
                  onClick={() => {
                    setShowStreakCelebration(false);
                    setCelebrationStreak(0);
                  }}
                  className="btn-primary w-full"
                >
                  Keep it going! 🚀
                </button>
              </div>
            </div>
          </div>
        )}

        {/* Input area */}
        <div className="bg-white border-t border-gray-200 p-4">

          {/* Current mood indicator */}
          {currentMood && (
            <div className="mb-3 p-2 bg-blue-50 rounded-lg flex items-center justify-between">
              <span className="text-sm text-blue-700">
                Current mood: <span className="font-medium">Level {currentMood}</span>
              </span>
              <button
                onClick={() => setCurrentMood(undefined)}
                className="text-blue-500 hover:text-blue-700 text-sm"
              >
                Clear
              </button>
            </div>
          )}

          {/* Voice mode hint */}
          {voiceEnabled && (
            <div className="mb-3 p-3 bg-gradient-to-r from-green-50 to-blue-50 border border-green-200 rounded-xl">
              <div className="flex items-center gap-2">
                <div className="w-2 h-2 bg-green-400 rounded-full animate-pulse" />
                <span className="text-sm text-green-700 font-medium">
                  🎙️ Voice Mode Active
                </span>
                <span className="text-xs text-green-600">
                  Pip will speak responses aloud
                </span>
              </div>
            </div>
          )}

          {/* Message form */}
          <form onSubmit={handleSubmit} className="flex gap-3 items-end">

            {/* Voice button with enhanced styling */}
            <div className="flex flex-col items-center">
              <VoiceButton
                onTranscript={handleVoiceInput}
                disabled={isTyping}
                className="mb-1"
              />
              <span className="text-xs text-gray-500 hidden sm:block">
                Voice
              </span>
            </div>

            {/* Text input */}
            <div className="flex-1">
              <textarea
                value={inputMessage}
                onChange={(e) => setInputMessage(e.target.value)}
                onKeyPress={(e) => {
                  if (e.key === 'Enter' && !e.shiftKey) {
                    e.preventDefault();
                    handleSubmit(e);
                  }
                }}
                placeholder={
                  voiceEnabled
                    ? "Type or speak your message... 🎙️"
                    : "Type your message here..."
                }
                className="w-full p-3 border-2 border-gray-200 rounded-xl focus:border-blue-500 focus:outline-none resize-none transition-all"
                rows={1}
                style={{ minHeight: '56px', maxHeight: '120px' }}
              />

              {/* Voice hint */}
              {!voiceEnabled && (
                <div className="mt-1 text-xs text-gray-400 flex items-center gap-1">
                  💡 Tip: Enable voice mode in the top bar to hear Pip speak!
                </div>
              )}
            </div>

            {/* Send button */}
            <div className="flex flex-col items-center">
              <button
                type="submit"
                disabled={!inputMessage.trim() || isTyping}
                className={`
                  w-14 h-14 rounded-xl flex items-center justify-center
                  transition-all transform active:scale-95
                  ${inputMessage.trim() && !isTyping
                    ? 'bg-blue-500 hover:bg-blue-600 text-white shadow-lg hover:scale-105'
                    : 'bg-gray-200 text-gray-400 cursor-not-allowed'
                  }
                `}
                aria-label="Send message"
              >
                <svg className="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                </svg>
              </button>
              <span className="text-xs text-gray-500 hidden sm:block mt-1">
                Send
              </span>
            </div>
          </form>

          {/* Quick mood buttons */}
          <div className="flex justify-center gap-2 mt-3">
            <button
              onClick={() => setCurrentMood(2)}
              className="p-2 text-lg hover:scale-110 transition-transform"
              title="Feeling down"
            >
              😔
            </button>
            <button
              onClick={() => setCurrentMood(3)}
              className="p-2 text-lg hover:scale-110 transition-transform"
              title="Feeling okay"
            >
              😐
            </button>
            <button
              onClick={() => setCurrentMood(4)}
              className="p-2 text-lg hover:scale-110 transition-transform"
              title="Feeling good"
            >
              😊
            </button>
            <button
              onClick={() => setCurrentMood(5)}
              className="p-2 text-lg hover:scale-110 transition-transform"
              title="Feeling excellent"
            >
              😄
            </button>
          </div>
        </div>
      </div>

      {/* Share Moment Modal */}
      <ShareMomentModal
        message={shareMessage}
        isOpen={shareModalOpen}
        onClose={() => {
          setShareModalOpen(false);
          setShareMessage(null);
        }}
      />

    </div>
  );
}
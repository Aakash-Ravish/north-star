        localStorage.removeItem('northstar_push');

        sendPipMessage("🔕 Daily reminders disabled. I'll miss sending you those little penguin notes! 🐧💙");
      }
    } catch (error) {
      console.error('Failed to toggle notifications:', error);
      alert('Failed to update notification settings. Please try again.');
    }
  };
        setShowMoodPicker(true);
        sendPipMessage("How are you feeling today? I'd love to check in with you! 😊");
      }, 2000);
    }
  }, [router]);

  // Load notification settings
  useEffect(() => {
    const settings = loadFromStorage<any>("northstar_settings", {});
    if (settings.notifications && typeof settings.notifications === "object") {
      setNotificationSettings(settings.notifications);
    }
  }, []);

  useEffect(() => {
    scrollToBottom();
  }, [messages]);

  // Update Pip mood based on user mood and animation states
  useEffect(() => {
    if (pipAnimation.state === 'happy') {
      setPipMood('playful');
    } else if (pipAnimation.state === 'thinking') {
      setPipMood('concerned');
    } else if (currentMood) {
      setPipMood(getPipMoodFromLevel(currentMood));
    } else {
      // Default to happy when user is engaged
      setPipMood(messages.length > 0 ? 'happy' : 'calm');
    }
  }, [currentMood, pipAnimation.state, messages.length]);

  // Update speaking state based on animation
  useEffect(() => {
    setPipSpeaking(pipAnimation.state === 'talking');
    // Simulate volume based on talking state
    if (pipAnimation.state === 'talking') {
      // Simulate natural volume variation during talking
      const volumeInterval = setInterval(() => {
        setPipVolume(0.3 + Math.random() * 0.6); // 0.3-0.9 range
      }, 200);

      return () => clearInterval(volumeInterval);
    } else {
      setPipVolume(0);
    }
  }, [pipAnimation.state]);

  const scrollToBottom = () => {
    messagesEndRef.current?.scrollIntoView({ behavior: 'smooth' });
  };

  const saveMessages = (newMessages: ChatMessage[]) => {
    if (user) {
      saveToStorage(`northstar_chat_${user.id}`, newMessages);
    }
  };

  const sendMessage = (content: string, mood?: MoodLevel) => {
    if (!user || !content.trim()) return;

    const newMessage: ChatMessage = {
      id: generateId(),
      content: content.trim(),
      sender: 'user',
      timestamp: new Date(),
      mood,
      type: 'text'
    };

    const updatedMessages = [...messages, newMessage];
    setMessages(updatedMessages);
    saveMessages(updatedMessages);

    // Clear input
    setInputMessage('');

    // Generate Pip response
    setTimeout(async () => {
      await generatePipResponse(content, mood, updatedMessages);
    }, 500 + Math.random() * 1000); // Random delay for natural feel
  };

  const sendPipMessage = (content: string) => {
    if (!user) return;

    const pipMessage: ChatMessage = {
      id: generateId(),
      content,
      sender: 'pip',
      timestamp: new Date(),
      type: 'text'
    };

    const updatedMessages = [...messages, pipMessage];
    setMessages(updatedMessages);
    saveMessages(updatedMessages);

    // Speak the message if voice is enabled
    if (voiceEnabled) {
      handlePipSpeech(content);
    }
  };

  const handlePipSpeech = async (text: string) => {
    if (!voiceEnabled) return;

    try {
      // Clean up the text for speech (remove emojis and markdown)
      const cleanText = text
        .replace(/[🐧💙🎉✨🌟💫🔥⭐🏆👑💪🤗🌈🌱💭💙❤️💕🎮🚀]/g, '') // Remove emojis
        .replace(/\*\*(.*?)\*\*/g, '$1') // Remove bold markdown
        .replace(/\*(.*?)\*/g, '$1') // Remove italic markdown
        .trim();

      if (cleanText) {
        const speechOptions: SpeechOptions = {
          rate: 0.85, // Slightly slower for Pip's warm personality
          pitch: 1.15, // Higher pitch for cuteness
          volume: 0.75,
          onStart: () => {
            setPipSpeaking(true);
          },
          onVolumeChange: (volume: number) => {
            setPipVolume(volume);
          },
          onEnd: () => {
            setPipSpeaking(false);
            setPipVolume(0);
          }
        };

        await speakText(cleanText, speechOptions);
      }
    } catch (error) {
      console.warn('Speech synthesis failed:', error);
      setPipSpeaking(false);
      setPipVolume(0);
    }
  };

  const toggleVoice = () => {
    const newSetting = !voiceEnabled;
    setVoiceEnabled(newSetting);
    setVoiceSettings(newSetting);

    if (!newSetting) {
      stopSpeaking(); // Stop any ongoing speech
    }

    // Send a confirmation message
    const message = newSetting
      ? "Voice output enabled! I'll speak my responses aloud. 🔊"
      : "Voice output disabled. I'll only show text responses now. 🔇";

    setTimeout(() => {

  const handleNotificationToggle = async () => {
    if (!('serviceWorker' in navigator) || !('PushManager' in window)) {
      alert('Push notifications are not supported in this browser.');
      return;
    }

    try {
      if (!notificationSettings.subscribed) {
        // Register service worker and subscribe
        const registration = await navigator.serviceWorker.register('/sw.js');
        
        const subscription = await registration.pushManager.subscribe({
          userVisibleOnly: true,
          applicationServerKey: process.env.NEXT_PUBLIC_VAPID_PUBLIC_KEY
        });

        // Update notification settings
        const updatedSettings = {
          ...notificationSettings,
          enabled: true,
          subscribed: true,
          subscription: subscription
        };
        
        setNotificationSettings(updatedSettings);
        
        // Save to storage
        const fullSettings = loadFromStorage('northstar_settings', {});
        fullSettings.notifications = updatedSettings;
        saveToStorage('northstar_settings', fullSettings);
        saveToStorage('northstar_push', subscription);

        sendPipMessage("🔔 Daily reminders enabled! I'll send you a gentle penguin nudge every day. 🐧💙");

      } else {
        // Unsubscribe
        const registration = await navigator.serviceWorker.getRegistration();
        const subscription = await registration?.pushManager.getSubscription();
        
        if (subscription) {
          await subscription.unsubscribe();
        }

        // Update notification settings
        const updatedSettings = {
          ...notificationSettings,
          enabled: false,
          subscribed: false,
          subscription: null
        };
        
        setNotificationSettings(updatedSettings);
        
        // Save to storage
        const fullSettings = loadFromStorage('northstar_settings', {});
        fullSettings.notifications = updatedSettings;
        saveToStorage('northstar_settings', fullSettings);
        localStorage.removeItem('northstar_push');

        sendPipMessage("🔕 Daily reminders disabled. I'll miss sending you those little penguin notes! 🐧💙");
      }
    } catch (error) {
      console.error('Failed to toggle notifications:', error);
      alert('Failed to update notification settings. Please try again.');
    }
  };
      sendPipMessage(message);
    }, 500);
  };

  const handleVoiceInput = (transcript: string) => {
    if (transcript.trim()) {
      setInputMessage(transcript);

      // Auto-send the voice message after a short delay
      setTimeout(() => {

  const handleNotificationToggle = async () => {
    if (!('serviceWorker' in navigator) || !('PushManager' in window)) {
      alert('Push notifications are not supported in this browser.');
      return;
    }

    try {
      if (!notificationSettings.subscribed) {
        // Register service worker and subscribe
        const registration = await navigator.serviceWorker.register('/sw.js');
        
        const subscription = await registration.pushManager.subscribe({
          userVisibleOnly: true,
          applicationServerKey: process.env.NEXT_PUBLIC_VAPID_PUBLIC_KEY
        });

        // Update notification settings
        const updatedSettings = {
          ...notificationSettings,
          enabled: true,
          subscribed: true,
          subscription: subscription
        };
        
        setNotificationSettings(updatedSettings);
        
        // Save to storage
        const fullSettings = loadFromStorage('northstar_settings', {});
        fullSettings.notifications = updatedSettings;
        saveToStorage('northstar_settings', fullSettings);
        saveToStorage('northstar_push', subscription);

        sendPipMessage("🔔 Daily reminders enabled! I'll send you a gentle penguin nudge every day. 🐧💙");

      } else {
        // Unsubscribe
        const registration = await navigator.serviceWorker.getRegistration();
        const subscription = await registration?.pushManager.getSubscription();
        
        if (subscription) {
          await subscription.unsubscribe();
        }

        // Update notification settings
        const updatedSettings = {
          ...notificationSettings,
          enabled: false,
          subscribed: false,
          subscription: null
        };
        
        setNotificationSettings(updatedSettings);
        
        // Save to storage
        const fullSettings = loadFromStorage('northstar_settings', {});
        fullSettings.notifications = updatedSettings;
        saveToStorage('northstar_settings', fullSettings);
        localStorage.removeItem('northstar_push');

        sendPipMessage("🔕 Daily reminders disabled. I'll miss sending you those little penguin notes! 🐧💙");
      }
    } catch (error) {
      console.error('Failed to toggle notifications:', error);
      alert('Failed to update notification settings. Please try again.');
    }
  };
        sendMessage(transcript.trim(), currentMood);
        setCurrentMood(undefined);
      }, 500);
    }
  };

  const generatePipResponse = async (userMessage: string, userMood?: MoodLevel, currentMessages: ChatMessage[] = messages) => {
    if (!user) return;

    // Start with Pip thinking
    setPipAnimation({ state: 'thinking' });
    setIsTyping(true);

    // Check if mock responses are enabled
    const useMockResponses = process.env.NEXT_PUBLIC_MOCK_RESPONSES === 'true';

    if (useMockResponses) {
      // Fallback to simple responses if mocking is enabled
      setPipAnimation({ state: 'talking' });

      const fallbackResponses = [
        "I hear you! Tell me more about that. 🐧💙",
        "That's really interesting. How does that make you feel? ✨",
        "Thanks for sharing with me. I'm here to listen! 🤗",
        "I appreciate you opening up. What's been on your mind? 💭"
      ];

      const response = fallbackResponses[Math.floor(Math.random() * fallbackResponses.length)];

      setTimeout(() => {

  const handleNotificationToggle = async () => {
    if (!('serviceWorker' in navigator) || !('PushManager' in window)) {
      alert('Push notifications are not supported in this browser.');
      return;
    }

    try {
      if (!notificationSettings.subscribed) {

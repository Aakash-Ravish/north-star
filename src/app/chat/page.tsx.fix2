// Sentiment analysis for Pip mood
const analyzeSentiment = (text: string): PipMood => {
  const lowerText = text.toLowerCase();

  // Happy/Playful keywords
  if (lowerText.match(/\b(amazing|awesome|great|fantastic|wonderful|excited|happy|love|perfect|brilliant|excellent)\b/)) {
    return 'playful';
  }

  // Sad keywords
  if (lowerText.match(/\b(sad|depressed|down|awful|terrible|hate|cry|crying|upset|hurt)\b/)) {
    return 'sad';
  }

  // Concerned/Anxious keywords
  if (lowerText.match(/\b(worried|anxious|scared|nervous|stress|stressed|overwhelmed|panic|afraid)\b/)) {
    return 'concerned';
  }

  // Calm/Neutral keywords
  if (lowerText.match(/\b(okay|fine|alright|calm|peaceful|relaxed|normal)\b/)) {
    return 'calm';
  }

  // Default to happy for positive engagement
  return 'happy';
};

export default function ChatPage() {

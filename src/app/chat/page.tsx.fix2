          ...notificationSettings,
          enabled: true,
          subscribed: true,
          subscription: subscription
        };
        
        setNotificationSettings(updatedSettings);
        
        // Save to storage
        const fullSettings = loadFromStorage('northstar_settings', {});
        fullSettings.notifications = updatedSettings;
        saveToStorage('northstar_settings', fullSettings);
        saveToStorage('northstar_push', subscription);

        sendPipMessage("🔔 Daily reminders enabled! I'll send you a gentle penguin nudge every day. 🐧💙");

      } else {
        // Unsubscribe
        const registration = await navigator.serviceWorker.getRegistration();
        const subscription = await registration?.pushManager.getSubscription();
        
        if (subscription) {
          await subscription.unsubscribe();
        }

        // Update notification settings
        const updatedSettings = {
          ...notificationSettings,
          enabled: false,
          subscribed: false,
          subscription: null
        };
        
        setNotificationSettings(updatedSettings);
        
        // Save to storage
        const fullSettings = loadFromStorage('northstar_settings', {});
        fullSettings.notifications = updatedSettings;
        saveToStorage('northstar_settings', fullSettings);
        localStorage.removeItem('northstar_push');

        sendPipMessage("🔕 Daily reminders disabled. I'll miss sending you those little penguin notes! 🐧💙");
      }
    } catch (error) {
      console.error('Failed to toggle notifications:', error);
      alert('Failed to update notification settings. Please try again.');
    }
  };
        setIsTyping(false);
        setPipAnimation({ state: 'idle' });
        sendPipMessage(response);
      }, 1500 + Math.random() * 1000);
      return;
    }

    try {
      // Convert current messages to the format expected by Anthropic
      const conversationMessages = currentMessages
        .filter(msg => msg.content.trim()) // Filter out empty messages
        .map(msg => ({
          role: msg.sender === 'user' ? 'user' : 'assistant',
          content: msg.content
        }));

      // Add the new user message
      conversationMessages.push({
        role: 'user',
        content: userMessage + (userMood ? ` (feeling level ${userMood}/5)` : '')
      });

      // Analyze sentiment and update Pip mood
      const detectedMood = analyzeSentiment(userMessage);
      setPipMood(detectedMood);

      // Build user memory object
      const recentMoodEntries = loadFromStorage(`northstar_mood_entries_${user.id}`, [])
        .slice(-10) // Last 10 mood entries
        .map((entry: any) => ({
          mood: entry.mood,
          timestamp: entry.timestamp,
          note: entry.note
        }));

      const userMemory = {
        name: user.name,
        preferredTone: user.preferredTone,
        recentMoods: recentMoodEntries,
        conversationContext: {
          topics: currentMessages
            .filter(msg => msg.sender === 'user')
            .slice(-3) // Last 3 user messages for topic context
            .map(msg => msg.content.substring(0, 50)), // First 50 chars
          lastInteraction: messages.length > 0 ? messages[messages.length - 1].content : '',
          userPersonality: [] // Could be enhanced later
        },
        preferences: {
          responseLength: 'short' as const,
          topics: [] // Could be enhanced later
        }
      };

      // Call the API with userMemory
      const response = await fetch('/api/chat', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          messages: conversationMessages,
          userMemory: userMemory
        }),
      });

      if (!response.ok) {
        throw new Error(`HTTP error! status: ${response.status}`);
      }

      // Check if it's a streaming response
      const contentType = response.headers.get('content-type');
      const isStreaming = contentType?.includes('text/event-stream');

      if (isStreaming) {
        // Handle streaming response
        const reader = response.body?.getReader();
        const decoder = new TextDecoder();

        if (!reader) {
          throw new Error('No response body');
        }

        // Create a new message for Pip's response
        const pipMessageId = generateId();
        let accumulatedText = '';
        let hasStartedStreaming = false;

        const pipMessage: ChatMessage = {
          id: pipMessageId,
          content: '',
          sender: 'pip',
          timestamp: new Date(),
          type: 'text'
        };

        // Add the initial empty message
        const initialMessages = [...currentMessages, pipMessage];
        setMessages(initialMessages);

        // Read the stream
        try {
          while (true) {
            const { done, value } = await reader.read();

            if (done) break;

            const chunk = decoder.decode(value);
            const lines = chunk.split('\n');

            for (const line of lines) {
              if (line.startsWith('data: ')) {
                try {
                  const data = JSON.parse(line.slice(6));

                  if (data.text) {
                    // Start talking animation on first text
                    if (!hasStartedStreaming) {
                      setPipAnimation({ state: 'talking' });
                      setIsTyping(false);
                      hasStartedStreaming = true;
                    }

                    accumulatedText += data.text;

                    // Update the message with accumulated text
                    setMessages(prevMessages => {
                      const updatedMessages = prevMessages.map(msg =>
                        msg.id === pipMessageId
                          ? { ...msg, content: accumulatedText }
                          : msg
                      );
                      saveMessages(updatedMessages);
                      return updatedMessages;
                    });
                  }

                  if (data.done || data.error) {
                    break;
                  }
                } catch (e) {
                  console.error('Error parsing streaming data:', e);
                }
              }
            }
          }
        } finally {
          reader.releaseLock();
          // Return to idle state when done
          setPipAnimation({ state: 'idle' });

          // Speak the completed message if voice is enabled
          if (voiceEnabled && accumulatedText) {
            handlePipSpeech(accumulatedText);
          }
        }
      } else {
        // Handle non-streaming response (fallback)
        const data = await response.json();

        if (data.text) {
          setPipAnimation({ state: 'talking' });
          setIsTyping(false);

          setTimeout(() => {

  const handleNotificationToggle = async () => {
    if (!('serviceWorker' in navigator) || !('PushManager' in window)) {
      alert('Push notifications are not supported in this browser.');
      return;
    }

    try {
      if (!notificationSettings.subscribed) {
        // Register service worker and subscribe
        const registration = await navigator.serviceWorker.register('/sw.js');
        
        const subscription = await registration.pushManager.subscribe({
          userVisibleOnly: true,
          applicationServerKey: process.env.NEXT_PUBLIC_VAPID_PUBLIC_KEY
        });

        // Update notification settings
        const updatedSettings = {
          ...notificationSettings,
          enabled: true,
          subscribed: true,
          subscription: subscription
        };
        
        setNotificationSettings(updatedSettings);
        
        // Save to storage
        const fullSettings = loadFromStorage('northstar_settings', {});
        fullSettings.notifications = updatedSettings;
        saveToStorage('northstar_settings', fullSettings);
        saveToStorage('northstar_push', subscription);

        sendPipMessage("🔔 Daily reminders enabled! I'll send you a gentle penguin nudge every day. 🐧💙");

      } else {
        // Unsubscribe
        const registration = await navigator.serviceWorker.getRegistration();
        const subscription = await registration?.pushManager.getSubscription();
        
        if (subscription) {
          await subscription.unsubscribe();
        }

        // Update notification settings
        const updatedSettings = {
          ...notificationSettings,
          enabled: false,
          subscribed: false,
          subscription: null
        };
        
        setNotificationSettings(updatedSettings);
        
        // Save to storage
        const fullSettings = loadFromStorage('northstar_settings', {});
        fullSettings.notifications = updatedSettings;
        saveToStorage('northstar_settings', fullSettings);
        localStorage.removeItem('northstar_push');

        sendPipMessage("🔕 Daily reminders disabled. I'll miss sending you those little penguin notes! 🐧💙");
      }
    } catch (error) {
      console.error('Failed to toggle notifications:', error);
      alert('Failed to update notification settings. Please try again.');
    }
  };
            setPipAnimation({ state: 'idle' });
            sendPipMessage(data.text);
          }, 500);
        } else {
          throw new Error('No response text received');
        }
      }

    } catch (error) {
      console.error('Error generating AI response:', error);

      // Reset states and show fallback
      setIsTyping(false);
      setPipAnimation({ state: 'idle' });

      const fallbackMessage = "I'm having a little penguin brain freeze right now, but I'm still here with you! 🐧💙 Can you try asking me again?";
      sendPipMessage(fallbackMessage);
    }
  };

  const handleSubmit = (e: React.FormEvent) => {
    e.preventDefault();
    sendMessage(inputMessage, currentMood);
    setCurrentMood(undefined);
  };

  const handleMoodSelect = (mood: MoodLevel) => {
    setCurrentMood(mood);
    setShowMoodPicker(false);

    // Update streak if it's a daily check-in
    if (!isToday(streak.lastDate)) {
      const newStreak = {
        current: streak.current + 1,
        longest: Math.max(streak.longest, streak.current + 1),
        lastDate: new Date(),
        lastVisit: new Date()
      };
      setStreak(newStreak);
      if (user) {
        saveToStorage(`northstar_streak_${user.id}`, newStreak);
      }
    }

    // Send mood-based message
    const moodMessage = `I'm feeling ${mood === 1 ? 'really low' :
                                      mood === 2 ? 'a bit down' :
                                      mood === 3 ? 'okay' :
                                      mood === 4 ? 'good' :
                                      'excellent'} today.`;
    sendMessage(moodMessage, mood);
  };


  const handleShareMessage = (message: ChatMessage) => {
    setShareMessage(message);
    setShareModalOpen(true);
  };

  const refreshDailyQuote = async () => {
    if (!user) return;

    try {
      // Clear cached quote
      localStorage.removeItem('northstar_daily_quote');

      // Fetch new quote
      const quote = await getDailyQuote(user.preferredTone);
      setDailyQuote(quote);
    } catch (error) {
      console.error('Error refreshing quote:', error);
    }
  };

  // Debug function to test streak milestones (only in development)
  const testStreakMilestone = (targetStreak: number) => {
    if (process.env.NODE_ENV !== 'development') return;

    const newStreak: Streak = {
      current: targetStreak,
      longest: Math.max(streak.longest, targetStreak),
      lastDate: new Date(),
      lastVisit: new Date()
    };

    setStreak(newStreak);
    saveToStorage('northstar_streak', newStreak);
    saveToStorage('northstar_best_streak', newStreak.longest);

    // Trigger celebration
    setCelebrationStreak(targetStreak);
    setShowStreakCelebration(true);
    setPipAnimation({ state: 'happy' });

    sendPipMessage(`🎉 ${getStreakMessage(targetStreak)} You've hit a ${targetStreak}-day streak! I'm so proud of you! 🐧💙`);

    setTimeout(() => {

  const handleNotificationToggle = async () => {
    if (!('serviceWorker' in navigator) || !('PushManager' in window)) {
      alert('Push notifications are not supported in this browser.');
      return;
    }

    try {
      if (!notificationSettings.subscribed) {
        // Register service worker and subscribe
        const registration = await navigator.serviceWorker.register('/sw.js');
        
        const subscription = await registration.pushManager.subscribe({
          userVisibleOnly: true,
          applicationServerKey: process.env.NEXT_PUBLIC_VAPID_PUBLIC_KEY
        });


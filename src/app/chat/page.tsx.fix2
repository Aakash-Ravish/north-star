  const messagesEndRef = useRef<HTMLDivElement>(null);
  const chatContainerRef = useRef<HTMLDivElement>(null);

  useEffect(() => {
    // Load user data
    const userData = loadFromStorage<User | null>('northstar_user', null);
    if (!userData) {
      router.push('/onboarding');
      return;
    }

    setUser(userData);

    // Load chat history and convert timestamps back to Date objects
    const chatHistory = loadFromStorage(`northstar_chat_${userData.id}`, []);
    const messagesWithDates = chatHistory.map((message: ChatMessage) => ({
      ...message,
      timestamp: new Date(message.timestamp)
    }));
    setMessages(messagesWithDates);

    // Load and calculate streak data
    const streakKey = 'northstar_streak';
    const bestStreakKey = 'northstar_best_streak';
    const today = new Date();

    const savedStreak = loadFromStorage(streakKey, {
      current: 0,
      longest: 0,
      lastDate: new Date(),
      lastVisit: new Date()
    });

    const savedBestStreak = loadFromStorage(bestStreakKey, 0);

    // Calculate new streak based on visit pattern
    const lastVisit = new Date(savedStreak.lastVisit || savedStreak.lastDate);
    const streakCalc = calculateStreak(lastVisit);

    let newStreak: Streak;

    if (streakCalc.shouldReset) {
      // Missed days, reset to day 1
      newStreak = {
        current: 1,
        longest: Math.max(savedStreak.longest, savedBestStreak),
        lastDate: today,
        lastVisit: today
      };
    } else if (streakCalc.isConsecutive) {
      // Consecutive day, increment
      const newCurrent = savedStreak.current + 1;
      newStreak = {
        current: newCurrent,
        longest: Math.max(savedStreak.longest, newCurrent, savedBestStreak),
        lastDate: today,
        lastVisit: today
      };

      // Check for milestone celebration
      if (isStreakMilestone(newCurrent)) {
        setTimeout(() => {

  const handleNotificationToggle = async () => {
    if (!('serviceWorker' in navigator) || !('PushManager' in window)) {
      alert('Push notifications are not supported in this browser.');
      return;
    }

    try {
      if (!notificationSettings.subscribed) {
        // Register service worker and subscribe
        const registration = await navigator.serviceWorker.register('/sw.js');
        
        const subscription = await registration.pushManager.subscribe({
          userVisibleOnly: true,
          applicationServerKey: process.env.NEXT_PUBLIC_VAPID_PUBLIC_KEY
        });

        // Update notification settings
        const updatedSettings = {
          ...notificationSettings,
          enabled: true,
          subscribed: true,
          subscription: subscription
        };
        
        setNotificationSettings(updatedSettings);
        
        // Save to storage
        const fullSettings = loadFromStorage('northstar_settings', {});
        fullSettings.notifications = updatedSettings;
        saveToStorage('northstar_settings', fullSettings);
        saveToStorage('northstar_push', subscription);

        sendPipMessage("🔔 Daily reminders enabled! I'll send you a gentle penguin nudge every day. 🐧💙");

      } else {
        // Unsubscribe
        const registration = await navigator.serviceWorker.getRegistration();
        const subscription = await registration?.pushManager.getSubscription();
        
        if (subscription) {
          await subscription.unsubscribe();
        }

        // Update notification settings
        const updatedSettings = {
          ...notificationSettings,
          enabled: false,
          subscribed: false,
          subscription: null
        };
        
        setNotificationSettings(updatedSettings);
        
        // Save to storage
        const fullSettings = loadFromStorage('northstar_settings', {});
        fullSettings.notifications = updatedSettings;
        saveToStorage('northstar_settings', fullSettings);
        localStorage.removeItem('northstar_push');

        sendPipMessage("🔕 Daily reminders disabled. I'll miss sending you those little penguin notes! 🐧💙");
      }
    } catch (error) {
      console.error('Failed to toggle notifications:', error);
      alert('Failed to update notification settings. Please try again.');
    }
  };
          setCelebrationStreak(newCurrent);
          setShowStreakCelebration(true);
          setPipAnimation({ state: 'happy' });

          // Send celebration message
          sendPipMessage(`🎉 ${getStreakMessage(newCurrent)} You've hit a ${newCurrent}-day streak! I'm so proud of you! 🐧💙`);

          // Reset animation after celebration
          setTimeout(() => {

  const handleNotificationToggle = async () => {
    if (!('serviceWorker' in navigator) || !('PushManager' in window)) {
